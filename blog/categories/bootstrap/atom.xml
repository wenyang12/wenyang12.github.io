            margin-right: 15px;
        }
        #mySpy > ul > li.active,#mySpy > ul > li.on{
            background: #ff3300;
        }
        #mySpy > ul > li.active > a,#mySpy > ul > li.on > a{
            text-decoration: none;
            color: #ffffff;
        }
        .box-spy-body-1,.box-spy-body-2,.box-spy-body-3{
            height: 600px;
            padding: 15px;
            color: #ffffff;
        }
        .box-spy-body-1{
            background: #0099cc;
        }
        .box-spy-body-2{
            background: #0172be;
        }
        .box-spy-body-3{
            background: #108040;
        }
        .js-fix-nav{
            position: fixed;
            top: 0;
            border-top: 2px solid  #ff3300;
            width: 980px;
            padding-top: 0;
        }
    </style>
</head>
<body></p>

<div class="box-spy">
